VITE_GITHUB_USERNAME=seu_usuario_github
GITHUB_TOKEN=seu_token_usado_apenas_no_build

GOOGLE_DRIVE_CERTIFICATES_FOLDER_ID=id_da_pasta_de_certificados
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Alternativa para pasta publica por link, usada apenas no build:
# GOOGLE_DRIVE_API_KEY=sua_api_key_do_google
# Ou use um arquivo local ignorado pelo git:
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=.secrets/google-service-account.json
