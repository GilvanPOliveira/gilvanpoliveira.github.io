{
  "name": "gilvanpoliveira.github.io",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:github": "node scripts/generate-github-portfolio.mjs",
    "generate:certificates": "node scripts/generate-certificates.mjs",
    "generate:data": "npm run generate:github && npm run generate:certificates",
